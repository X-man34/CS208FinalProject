          p Lorem ipsum dolor sit amet, consectetur adipiscing elit.
        .button-row
          a.button.button--primary(href='/comments') Read Customer Comments
          a.button.button--secondary(href=orderUrl target='_blank' rel='noreferrer') Open Order Link
